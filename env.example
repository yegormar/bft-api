# Copy to .env and set values. Required unless marked optional.

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Assessment mode: scenarios (LLM-generated questions) or triangles (fixed triangle assessment set). Required.
BFT_ASSESSMENT_MODE=triangles

# Question store and pregen (optional)
BFT_QUESTIONS_STORE_DIR=./data/questions-store
# Try store first (true) or generate with LLM first (false). Required.
BFT_SCENARIO_STORE_FIRST=false
# BFT_PREGEN_QUEUE_CAP=5
# BFT_PREGEN_REFILL_THRESHOLD=1
# BFT_QUESTION_LLM_TIMEOUT_MS=45000

# LLM configuration - Ollama Cloud
LLM_PROVIDER=ollama_cloud
LLM_BASE_URL=https://ollama.com
LLM_API_KEY=
LLM_MODEL=qwen3.5:397b
LLM_THINK=false
# LLM_THINK_LEVEL=low

# LLM configuration - Ollama local
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=gemma3:12b
# LLM_THINK=false

LLM_WEB_SEARCH=true
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=32768
LLM_NUM_CTX=32768
LLM_TOP_P=0.9
LLM_CHECKUP_INTERVAL_SEC=180

# Prompts (conf/ paths; scenario steps required for interview)
LLM_REPORT_PROFILE_SYSTEM_PROMPT_FILE=conf/report_profile_system_prompt.txt
# AI-era context appended to report profile prompt. Empty = disabled. Set to path to enable (e.g. conf/report_ai_context.txt).
LLM_REPORT_AI_CONTEXT_FILE=
BFT_SCENARIO_STEP1_INSTRUCTIONS_FILE=conf/scenario_step1.txt
BFT_SCENARIO_STEP3_INSTRUCTIONS_FILE=conf/scenario_step3.txt

# Optional: interview limits, pregen, dev
# MIN_SIGNAL_PER_DIMENSION=1
# MAX_INTERVIEW_QUESTIONS=30
# BFT_DEV_MAX_QUESTIONS=5
# BFT_SKIP_BACKGROUND_PREGEN=1

# Optional: enable admin API (scenario stats, list, delete). Set to 1 to mount /api/admin.
# BFT_ADMIN_ENABLED=1

# Feedback: file path to append user feedback (one JSON line per submission). Required.
BFT_FEEDBACK_FILE=./data/feedback.jsonl

# Careers: LLM career paths two-step prompts and AI context. All required for AI career paths; math-based job match always available.
CAREERS_LLM_STEP1_PROMPT_FILE=conf/career_paths_step1.txt
CAREERS_LLM_STEP2_PROMPT_FILE=conf/career_paths_step2.txt
CAREERS_LLM_AI_CONTEXT_FILE=conf/report_ai_context.txt

# Careers match (math): weight for skill vs dimension fit. Both required; must sum to 1.
OCCUPATION_SKILL_WEIGHT=0.6
OCCUPATION_DIMENSION_WEIGHT=0.4
