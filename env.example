# Copy to .env and set values. All listed below are required unless marked optional.

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# LLM – set LLM_PROVIDER to: ollama (local) or ollama_cloud
LLM_PROVIDER=ollama_cloud
LLM_BASE_URL=https://ollama.com
# For Cloud, use a model from the API list (script validates; run with wrong model to see list). Examples: qwen3.5:397b, gpt-oss:20b, qwen3-next:80b
LLM_MODEL=qwen3.5:397b
LLM_API_KEY=
LLM_WEB_SEARCH=true
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=32768
LLM_TOP_P=0.9
# Context window size (input tokens).
LLM_NUM_CTX=32768
# Optional: for GPT-OSS only. Reasoning level "low"|"medium"|"high" ("low" = minimal reasoning, o4-mini-style). When set, used automatically when LLM_MODEL is gpt-oss.
# LLM_THINK_LEVEL=low
# For thinking models: true/false (or for GPT-OSS use low|medium|high). Used when LLM_MODEL is not gpt-oss; for gpt-oss the level is taken from LLM_THINK_LEVEL or LLM_THINK.
LLM_THINK=false
# Seconds between periodic LLM checkups (validates connectivity, keeps model loaded).
LLM_CHECKUP_INTERVAL_SEC=180

# Prompts – paths relative to project root (conf/). All required; process exits if missing or file not found.
LLM_SYSTEM_PROMPT_FILE=conf/assessment_system_prompt.txt
# LLM_HANDOFF_SYSTEM_PROMPT_FILE=conf/assessment_handoff_system_prompt.txt
# Report synthesis (required).
LLM_REPORT_PROFILE_SYSTEM_PROMPT_FILE=conf/report_profile_system_prompt.txt
LLM_REPORT_HYBRID_SYSTEM_PROMPT_FILE=conf/report_hybrid_system_prompt.txt
# Profession/career recommendations (required).
LLM_REPORT_RECOMMENDATIONS_SYSTEM_PROMPT_FILE=conf/report_recommendations_system_prompt.txt
# Two-step scenario generation: step 1 (scenario only) and step 2 (score assignment). Required when using LLM for interview questions.
BFT_SCENARIO_STEP1_INSTRUCTIONS_FILE=conf/scenario_step1_instructions.txt
BFT_SCENARIO_STEP2_INSTRUCTIONS_FILE=conf/scenario_step2_instructions.txt

# Interview – coverage and stopping (optional). See README.
# MIN_SIGNAL_PER_DIMENSION=1
# MAX_INTERVIEW_QUESTIONS=30
# Development only: finish interview after N questions (e.g. BFT_DEV_MAX_QUESTIONS=5). Ignored when NODE_ENV is not development.
# BFT_DEV_MAX_QUESTIONS=5

# Directory for persistent question store (survives restart, keyed by profile).
BFT_QUESTIONS_STORE_DIR=./data/questions-store
# Question generation component: timeout in ms for LLM call before falling back to store. Required when using assessment next-question flow.
# BFT_QUESTION_LLM_TIMEOUT_MS=20000
# Pre-generation depth: max questions to generate in the background (default 5). Set to 0 to disable pregen.
# BFT_PREGEN_QUEUE_CAP=5
# Pre-generation refill: when queue drops below this, trigger a new background run (default 1). Must be < BFT_PREGEN_QUEUE_CAP.
# BFT_PREGEN_REFILL_THRESHOLD=1
# Test-only: set to 1 to disable background question pre-generation (used by npm test).
# BFT_SKIP_BACKGROUND_PREGEN=1

# NOC script (src/scripts/fetch-noc-occupations.js). Required when running that script.
# Path to NOC 2021 Elements CSV and output JSON path. Or pass as CLI: node src/scripts/fetch-noc-occupations.js <elements.csv> <output.json>
# NOC_ELEMENTS_CSV=../docs/noc_2021_version_1.0_-_elements.csv
# NOC_JSON_OUTPUT=./data/noc-2021.json

# NOC enrichment script (src/scripts/enrich-noc-with-mappings.js). Optional. Uses same LLM_* vars as above.
# node src/scripts/enrich-noc-with-mappings.js [--debug] [--input path] [--output path] [--limit N]
# NOC_JSON_INPUT=./data/noc-2021.json
# NOC_JSON_OUTPUT=./data/noc-2021-enriched.json
# NOC_ENRICHMENT_SYSTEM_PROMPT_FILE=conf/noc_enrichment_system_prompt.txt
# NOC_ENRICHMENT_LIMIT=5
# NOC_ENRICHMENT_NOC=00010   # process only this NOC code (exact match)
# DEBUG=1
# Optional: request timeout in ms (default 300000 = 5 min). Increase if large local models are slow.
# NOC_LLM_TIMEOUT_MS=300000
# Optional: per-attempt timeout in ms; when exceeded the request is restarted (retried). If set, overrides single-attempt timeout for that occupation.
# NOC_LLM_REQUEST_TIMEOUT_MS=120000
# Optional: max retries when using NOC_LLM_REQUEST_TIMEOUT_MS (default 3).
# NOC_LLM_MAX_RETRIES=3
# Optional: delay in ms between LLM requests only (default 0). Not applied when skipping already-enriched occupations.
# NOC_LLM_DELAY_MS=1000
# For local Ollama on 24GB (e.g. RTX 3090): 27B+ models can OOM or hang. Use a smaller model (e.g. qwen2.5-coder:14b, deepseek-r1:14b) or set LLM_NUM_CTX=8192.
# For thinking models: set LLM_THINK=false (or for GPT-OSS set LLM_THINK_LEVEL=low) in .env for faster NOC enrichment.
