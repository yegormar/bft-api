# Scripts only. Copy to scripts/.env when running NOC/prep scripts. Not used by the API.

# fetch-noc-occupations.js (or pass CLI: <elements.csv> <output.json>)
# NOC_ELEMENTS_CSV=./docs/noc_2021_version_1.0_-_elements.csv
# NOC_JSON_OUTPUT=./data/noc-2021.json

# enrich-noc-with-mappings.js
# NOC_JSON_INPUT=./data/noc-2021.json
# NOC_JSON_OUTPUT=./data/noc-2021-enriched.json
# NOC_ENRICHMENT_SYSTEM_PROMPT_FILE=prompts/noc_enrichment_system_prompt.txt
# NOC_ENRICHMENT_LIMIT=5
# NOC_ENRICHMENT_NOC=00010
# DEBUG=1

# enrich-noc: LLM request tuning (optional)
# NOC_LLM_TIMEOUT_MS=300000
# NOC_LLM_REQUEST_TIMEOUT_MS=120000
# NOC_LLM_MAX_RETRIES=3
# NOC_LLM_DELAY_MS=1000

# LLM_* come from bft-api/.env. Overrides here apply when scripts/.env is used.
